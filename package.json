{
  "name": "@turkeryakup/antigravity-mcp",
  "version": "3.0.1",
  "description": "MCP server exposing Google Antigravity (agy CLI / Gemini) to Claude and other MCP clients: async task jobs, large-codebase analysis, filesystem tools, model selection and more.",
  "main": "index.js",
  "bin": {
    "antigravity-mcp": "index.js"
  },
  "scripts": {
    "start": "node index.js",
    "check": "node --check index.js",
    "test": "node --check index.js",
    "prepublishOnly": "node --check index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "antigravity",
    "google-antigravity",
    "agy",
    "gemini",
    "claude",
    "anthropic",
    "ai-agent",
    "codebase-analysis"
  ],
  "author": "Türker Yakup",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "index.js"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TurkerYakup/mcp-server-google-antigravity.git"
  },
  "homepage": "https://github.com/TurkerYakup/mcp-server-google-antigravity#readme",
  "bugs": {
    "url": "https://github.com/TurkerYakup/mcp-server-google-antigravity/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xterm/headless": "^6.0.0",
    "zod": "^3.0.0"
  },
  "optionalDependencies": {
    "node-pty": "^1.1.0"
  },
  "os": [
    "win32",
    "darwin",
    "linux"
  ]
